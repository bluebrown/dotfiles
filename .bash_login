#!/usr/bin/env bash

if [ -f "$HOME/.profile" ]; then
  . "$HOME/.profile"
fi

function has() {
  hash "$1" 2>/dev/null
}

export PATH="$HOME/go/bin:/usr/local/go/bin:$HOME/.cargo/bin:$PATH"
export HOMEBREW_NO_ANALYTICS=1

if has nvim; then
  export EDITOR=nvim
else
  export EDITOR=vi
fi

alias v='"${EDITOR:-vi}"'

if has batcat; then
  export MANPAGER="sh -c 'col -bx | batcat -l man -p'"
  export MANROFFOPT="-c"
  alias bat="batcat"
  alias cat="bat --plain"
fi

if has starship; then
  eval "$(starship init bash)"
fi

if has direnv; then
  eval "$(direnv hook bash)"
fi

if has fzf; then
  eval "$(fzf --bash)"
fi

if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

if [ -f "$HOME/.cargo/env" ]; then
  . "$HOME/.cargo/env"
fi

if has lsd; then
  alias tree="lsd -A -I .git --tree"
  alias ls="lsd"
fi

alias cfg='git --git-dir "$HOME/dotfiles.git" --work-tree "$HOME"'
alias fd="fdfind"
alias gu="gitui"

alias d="docker"
alias dc="docker compose"
alias k="kubectl"
alias ksc="k config use-context"
alias ksn="k config set-context --current --namespace"
alias kz="kustomize"
alias kb="kustomize build"
alias tf="terraform"
alias fc="firecracker"

alias sf='fd --type f --hidden --exclude .git --print0 |
	fzf -- --read0 --print0 --exit-0 --preview "batcat --color=always --style=numbers --line-range=:500 {}" |
	xargs -r -0 -o ${EDITOR:-vim}'

alias pubip='dig +short myip.opendns.com @resolver1.opendns.com'
