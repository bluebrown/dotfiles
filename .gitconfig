[user]
  name = bluebrown
  email = 39703898+bluebrown@users.noreply.github.com
[alias]
  append = !git add $1 && git commit --amend --no-edit
[core]
  autocrlf = input
  whitespace = trailing-space,space-before-tab,indent-with-non-tab
[init]
  defaultBranch = main
[pull]
  rebase = true
[commit]
  gpgsign = true
[tag]
	gpgSign = true
